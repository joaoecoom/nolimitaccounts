{
  "rewrites": [
    {
      "source": "/br",
      "destination": "/index-br.html"
    },
    {
      "source": "/en",
      "destination": "/index-en.html"
    },
    {
      "source": "/gui2331/br",
      "destination": "/index-gui2331-br.html"
    },
    {
      "source": "/gui2331/en",
      "destination": "/index-gui2331-en.html"
    },
    {
      "source": "/gui2331",
      "destination": "/index-gui2331.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}

